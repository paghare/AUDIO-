# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/audiorefinement?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── S3-compatible Storage ─────────────────────────────────────────────────────
S3_BUCKET_NAME=audiorefinement
S3_REGION=auto
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com  # or AWS endpoint
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_PUBLIC_URL=https://cdn.yourdomain.com  # CDN / public URL prefix

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-long-random-secret

# ── Processing Limits ─────────────────────────────────────────────────────────
FREE_MAX_FILE_SIZE_MB=50
PRO_MAX_FILE_SIZE_MB=500
PREMIUM_MAX_FILE_SIZE_MB=2048
FREE_MONTHLY_MINUTES=30
PRO_MONTHLY_MINUTES=300
PREMIUM_MONTHLY_MINUTES=9999
